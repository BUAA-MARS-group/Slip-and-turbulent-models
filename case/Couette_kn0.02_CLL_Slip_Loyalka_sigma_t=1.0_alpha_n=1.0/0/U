FoamFile
{
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    up
    {
        type            CLL_SlipU_Loyalka;
        accommodationCoeff_t  1.0;
        accommodationCoeff_n  1.0;
        Uwall           uniform (350 0 0);
        value           uniform (350 0 0);
        thermalCreep    true;
        curvature       true;
    }

    down
    {
        type            CLL_SlipU_Loyalka;
        accommodationCoeff_t  1.0;
        accommodationCoeff_n  1.0;
        Uwall           uniform (-350 0 0);
        value           uniform (-350 0 0);
        thermalCreep    true;
        curvature       true;
    }
    
    left
    {
        type            cyclic;
    }

    right
    {
        type            cyclic;
    }

    defaultPatch
    {
        type            empty;
    }

}

