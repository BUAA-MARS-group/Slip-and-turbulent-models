FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      yPlus;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    up
    {
        type            calculated;
        value           nonuniform List<scalar> 3(0.266417 0.266417 0.266417);
    }
    down
    {
        type            calculated;
        value           uniform 0.266417;
    }
    left
    {
        type            cyclic;
    }
    right
    {
        type            cyclic;
    }
    defaultFaces
    {
        type            empty;
    }
}


